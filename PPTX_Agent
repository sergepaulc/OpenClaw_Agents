#!/usr/bin/env python3
import argparse
import datetime as dt
import os
import re
from pptx import Presentation

def iter_text_runs(shape):
    """Yield (run, text_frame) for all runs in a shape."""
    if not shape.has_text_frame:
        return
    tf = shape.text_frame
    for p in tf.paragraphs:
        for run in p.runs:
            yield run, tf

def replace_in_pptx(src_path: str, find: str, repl: str, slide_idx: int | None):
    prs = Presentation(src_path)
    changes = 0

    slides = prs.slides
    slide_range = range(len(slides)) if slide_idx is None else [slide_idx]

    for i in slide_range:
        if i < 0 or i >= len(slides):
            continue
        for shape in slides[i].shapes:
            for run, _tf in iter_text_runs(shape):
                if find in run.text:
                    run.text = run.text.replace(find, repl)
                    changes += 1

    return prs, changes

def main():
    ap = argparse.ArgumentParser(description="Edit PPTX safely (writes a new file).")
    ap.add_argument("--in", dest="inp", required=True, help="Input .pptx path")
    ap.add_argument("--outdir", required=True, help="Output directory")
    ap.add_argument("--find", required=True, help="Text to find")
    ap.add_argument("--replace", required=True, help="Replacement text")
    ap.add_argument("--slide", type=int, default=None, help="1-based slide number (optional)")
    args = ap.parse_args()

    src = os.path.abspath(args.inp)
    outdir = os.path.abspath(args.outdir)

    if not os.path.exists(src) or not src.lower().endswith(".pptx"):
        raise SystemExit("Input file not found or not a .pptx")

    os.makedirs(outdir, exist_ok=True)

    slide_idx = None if args.slide is None else args.slide - 1  # convert to 0-based
    prs, changes = replace_in_pptx(src, args.find, args.replace, slide_idx)

    base = os.path.splitext(os.path.basename(src))[0]
    stamp = dt.datetime.now().strftime("%Y%m%d-%H%M%S")
    out_path = os.path.join(outdir, f"{base}_edited_{stamp}.pptx")
    prs.save(out_path)

    print(out_path)
    print(f"changes={changes}")

if __name__ == "__main__":
    main()

